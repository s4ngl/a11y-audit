# ─────────────────────────────────────────────────────────────────────────────
# a11y-audit environment config
# Copy this file to .env in the same directory as a11y-audit.sh, then fill in
# your values. The script sources .env automatically on startup.
#
#   cp a11y-audit.env.txt .env
# ─────────────────────────────────────────────────────────────────────────────


# ─── WAVE WebAIM API ──────────────────────────────────────────────────────────
#
# Required for WAVE scanning. Get a key at: https://wave.webaim.org/api/
# Free tier: 100 credits/month. Each URL scan costs 1 credit.
# Omit or leave blank to skip WAVE automatically (no error).

WAVE_API_KEY=your_wave_api_key_here


# ─── OPTIONAL OVERRIDES ───────────────────────────────────────────────────────
#
# These are already set to sensible defaults in the script.
# Uncomment and change here to override without editing the script itself.

# WCAG conformance level to test against. Options: WCAG2A | WCAG2AA | WCAG2AAA
# WCAG_STANDARD=WCAG2AA

# How long Pa11y waits for a page to respond before giving up (milliseconds).
# PA11Y_TIMEOUT=60000

# How long Lighthouse is allowed to run per URL before being killed (seconds).
# LIGHTHOUSE_TIMEOUT=60

# Max number of Lighthouse jobs to run at the same time.
# Reduce to 1 on low-memory machines; increase cautiously on powerful ones.
# MAX_PARALLEL=3
